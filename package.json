{
  "name": "anime-trinity-theme",
  "icon": "icon.png",
  "displayName": "Anime Trinity Theme",
  "description": "Three anime-inspired VS Code themes: One Piece Dark, Robin Cozy, and Purple Blue.",
  "version": "1.0.0",
  "publisher": "luvruv",
  "engines": {
    "vscode": "^1.70.0"
  },
  "repository": {

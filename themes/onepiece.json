    "notifications.foreground": "#e2e8f0",
    "notifications.border": "#1e2d47",
    "notificationLink.foreground": "#38bdf8"
    },

"tokenColors": [
    {
    "name": "Comments",
    "scope": ["comment", "punctuation.definition.comment"],
    "settings": {
        "foreground": "#475569",
        "fontStyle": "italic"
    }
    },
    {
    "name": "Keywords",
    "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
    ],
    "settings": {
        "foreground": "#ef4444",
        "fontStyle": "bold"
    }
    },
    {
    "name": "Strings",
    "scope": ["string", "string.quoted", "string.template"],
    "settings": { "foreground": "#22c55e" }
    },
    {
    "name": "String Escape & Template Expressions",
    "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression"
    ],
    "settings": { "foreground": "#fbbf24" }
    },
    {
    "name": "Functions",
    "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
    ],
    "settings": { "foreground": "#38bdf8" }
    },
    {
    "name": "Function Parameters",
    "scope": ["variable.parameter"],
    "settings": {
        "foreground": "#fdba74",
        "fontStyle": "italic"
    }
    },
    {
    "name": "Variables",
    "scope": ["variable", "variable.other", "variable.other.readwrite"],
    "settings": { "foreground": "#e2e8f0" }
    },
    {
    "name": "Constants",
    "scope": [
        "constant",
        "variable.other.constant",
        "constant.language"
    ],
    "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
    }
    },
    {
    "name": "Numbers",
	"scope": ["constant.numeric"],
    "settings": { "foreground": "#fb923c" }
    },
    {
    "name": "Booleans & Null",
    "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
    ],
    "settings": {
        "foreground": "#f97316",
        "fontStyle": "bold"
    }
    },
    {
    "name": "Classes & Types",
    "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "entity.other.inherited-class"
    ],
    "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
    }
    },
    {
    "name": "HTML Tags",
    "scope": ["entity.name.tag"],
    "settings": { "foreground": "#ef4444" }
    },
    {
    "name": "HTML Attributes",
    "scope": ["entity.other.attribute-name"],
    "settings": { "foreground": "#fbbf24" }
    },
    {
    "name": "CSS Properties",
    "scope": ["support.type.property-name.css"],
    "settings": { "foreground": "#38bdf8" }
    },
    {
    "name": "CSS Values",
    "scope": ["support.constant.property-value.css"],
    "settings": { "foreground": "#22c55e" }
    },
    {
    "name": "CSS Selectors",
    "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
    ],
    "settings": { "foreground": "#fbbf24" }
    },
    {
    "name": "Operators",
    "scope": ["keyword.operator"],
    "settings": { "foreground": "#94a3b8" }
    },
    {
    "name": "Punctuation",
    "scope": ["punctuation"],
    "settings": { "foreground": "#64748b" }
    },
    {
    "name": "Imports & Exports",
    "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
    ],
    "settings": { "foreground": "#f472b6" }
    },
    {
    "name": "Decorators & Annotations",
    "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
    ],
    "settings": { "foreground": "#f97316" }
    },
    {
    "name": "JSON Keys",
    "scope": [
        "support.type.property-name.json",
        "meta.object-literal.key"
    ],
    "settings": { "foreground": "#38bdf8" }
    },
    {
    "name": "Python Self",
    "scope": ["variable.language.special.self.python"],
    "settings": {
        "foreground": "#ef4444",
        "fontStyle": "italic"
    }
    },
    {
    "name": "Invalid",
    "scope": ["invalid"],
    "settings": {
        "foreground": "#fca5a5",
        "fontStyle": "strikethrough"
    }
    }
]
}
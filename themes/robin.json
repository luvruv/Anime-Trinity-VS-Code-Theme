    "input.placeholderForeground": "#b5a795",
    "inputOption.activeBorder": "#7c3aed",
    "dropdown.background": "#f5f0eb",
    "dropdown.foreground": "#2d2320",
    "dropdown.border": "#ddd5c8",

    "button.background": "#7c3aed",

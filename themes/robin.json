    "button.secondaryBackground": "#ddd5c8",
    "button.secondaryForeground": "#2d2320",

    "scrollbarSlider.background": "#c4b5a080",
    "scrollbarSlider.hoverBackground": "#a08878aa",
    "scrollbarSlider.activeBackground": "#7c3aed60",

    "gitDecoration.addedResourceForeground": "#16a34a",
    "gitDecoration.modifiedResourceForeground": "#d97706",
    "gitDecoration.deletedResourceForeground": "#b91c1c",
    "gitDecoration.untrackedResourceForeground": "#22c55e",
    "gitDecoration.ignoredResourceForeground": "#b5a795",

    "minimap.background": "#ede5dc",
    "minimap.selectionHighlight": "#7c3aed40",

    "breadcrumb.foreground": "#a08878",
    "breadcrumb.activeForeground": "#7c3aed",
    "breadcrumb.background": "#f5f0eb",

    "diffEditor.insertedTextBackground": "#16a34a18",
    "diffEditor.removedTextBackground": "#b91c1c18",

    "notifications.background": "#f5f0eb",
    "notifications.foreground": "#2d2320",
    "notificationLink.foreground": "#7c3aed"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9ca3af",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#16a34a" }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#d97706" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#2563eb" }
    },
    {
      "name": "Function Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#c2410c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#2d2320" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#d97706",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ea580c" }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#b91c1c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5b21b6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#7c3aed" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c2410c" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#2563eb" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#16a34a" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#5b21b6" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#6b7280" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#9ca3af" }
    },
    {
      "name": "Imports & Exports",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": { "foreground": "#be185d" }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#d97706" }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#2563eb" }
    },
    {
      "name": "Python Self",
      "scope": ["variable.language.special.self.python"],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#b91c1c",
        "fontStyle": "underline"
      }
    }
  ]
}
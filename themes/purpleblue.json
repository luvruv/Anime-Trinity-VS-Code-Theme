    "notifications.foreground": "#cdd6f4",
    "notifications.border": "#131827",
    "notificationLink.foreground": "#60a5fa"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#3d4f6e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a855f7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#22d3ee" }
    },
    {
      "name": "String Escape & Template Expressions",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#f9e2af" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "name": "Function Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#93c5fd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#cdd6f4" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#fab387" }
    },
    {
      "name": "Booleans & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c4b5fd",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#a5b4fc" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#a855f7" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c4b5fd" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#22d3ee" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#c4b5fd" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#7a8baa" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#4a5878" }
    },
    {
      "name": "Imports & Exports",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": { "foreground": "#f0abfc" }
    },
    {
      "name": "Decorators & Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#f9e2af" }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "name": "Python Self",
      "scope": ["variable.language.special.self.python"],
      "settings": {
        "foreground": "#a855f7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type Annotations",
      "scope": ["storage.type.annotation"],
      "settings": { "foreground": "#f9e2af" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "underline"
      }
    }
  ]
}
